        function ExportRackPicture(
                                    variable iEasyCodeIIRackID,      // easyCodeIIRackID
                                    variable iAsynchronPictureSave,
                                    variable iPictureFilenamePath,
                                    variable iPictureFormat,
                                    variable iDrawAnalysedInformation,
